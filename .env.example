# Copy to .env and fill in values. Never commit .env.

PORT=8000
NODE_ENV=development

# JWT (generate strong random strings for production)
TOKEN_KEY=
TOKEN=

# Session (defaults to TOKEN_KEY if unset; set SESSION_SECRET in production)
SESSION_SECRET=
SESSION_MAX_AGE_MS=86400000
# Set to "false" to allow session cookie over http://localhost
SESSION_COOKIE_SECURE=false

# MySQL (required)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=railway
DB_CONNECTION_LIMIT=20
